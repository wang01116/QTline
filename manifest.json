{
  "manifest_version": 3,
  "name": "QTline",
  "version": "1.0.0",
  "description": "为 Qwen AI 增强对话时间轴导航、提示词管理、批量操作和主题切换功能",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chat.qwen.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chat.qwen.ai/*"],
      "js": ["scripts/content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles/*", "scripts/*", "icons/*"],
      "matches": ["https://chat.qwen.ai/*"]
    }
  ]
}
